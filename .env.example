# Copy to .env and adjust if needed
# ENV can be: dev | prod
ENV=dev

PGHOST=localhost
PGPORT=5432
PGDATABASE=globalcart
PGUSER=globalcart
PGPASSWORD=globalcart

# --- Security / Auth ---
# Required in prod. In dev, can be left empty, but JWT-authenticated routes will fail.
JWT_SECRET=
JWT_ISSUER=globalcart
JWT_AUDIENCE=globalcart
JWT_TTL_MINUTES=120

# --- Rate limiting (best-effort demo middleware) ---
RATE_LIMIT_ENABLED=1
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# --- Razorpay (sandbox) ---
# Used by /api/payments/razorpay/order and /api/payments/razorpay/webhook
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Email/OTP Delivery (choose one) ---

# Option 1: SendGrid (recommended)
# 1. Sign up at https://signup.sendgrid.com/
# 2. Verify your sender email/domain in Settings > Sender Authentication
# 3. Create an API Key: Settings > API Keys > Create API Key > Restricted Access > Mail Send enabled
# SENDGRID_API_KEY=SG.xxxxx...
# SENDGRID_FROM_EMAIL=noreply@yourdomain.com   # Must be a verified sender in SendGrid

# Option 2: SMTP (e.g., Gmail App Password)
# 1. Enable 2FA on your Gmail account
# 2. Create an App Password: https://myaccount.google.com/apppasswords
# 3. Use 16-character App Password below
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USE_TLS=1
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx   # 16-char App Password
# SMTP_FROM_EMAIL=you@gmail.com

# --- OTP behavior ---
# DEMO_SHOW_OTP=1   # Show OTP in API response when email isn't configured (set to 0 in production)
